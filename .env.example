#################################################################
# VeriCall — Environment Variables
# Copy this file to .env and fill in the actual API keys
#################################################################

# Daily.co API key for video call room creation
DAILY_API_KEY=your_daily_co_api_key_here

# Deepgram API key for real-time speech-to-text
DEEPGRAM_API_KEY=your_deepgram_api_key_here

# Groq API key for Llama 3.3 70B agent
GROQ_API_KEY=your_groq_api_key_here

# Optional: also mirror DB writes to JSONL for debugging/demo portability
AUDIT_WRITE_JSONL_COPY=false
